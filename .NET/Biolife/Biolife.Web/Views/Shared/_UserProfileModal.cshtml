@using System.Security.Claims

@if (User.Identity?.IsAuthenticated == true)
{
    var userName = User.FindFirstValue(ClaimTypes.Name) ?? "Biolife User";
    var userEmail = User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var userInitial = string.IsNullOrWhiteSpace(userName)
        ? "U"
        : userName.Trim()[0].ToString().ToUpperInvariant();

    <div id="user-profile-modal" class="user-profile-modal-shell" hidden aria-hidden="true">
        <div class="user-profile-modal-backdrop" data-profile-close></div>
        <section class="user-profile-modal" role="dialog" aria-modal="true" aria-labelledby="user-profile-title">
            <div class="user-profile-modal-header">
                <div>
                    <span class="user-profile-kicker">Account settings</span>
                    <h2 id="user-profile-title">User Profile</h2>
                </div>
                <button type="button" class="user-profile-close" data-profile-close aria-label="Close profile">
                    <i class="fa fa-times" aria-hidden="true"></i>
                </button>
            </div>

            <div class="user-profile-status" id="user-profile-status" role="status" aria-live="polite"></div>

            <div class="user-profile-grid">
                <div class="user-profile-photo-card">
                    <div class="user-profile-avatar-wrap">
                        <img id="profile-photo-preview" class="user-profile-avatar" alt="Profile photo" hidden>
                        <span id="profile-photo-initials" class="user-profile-initials">@userInitial</span>
                    </div>
                    <input id="profile-photo-input" class="user-profile-hidden-file" type="file" accept="image/*" tabindex="-1" aria-hidden="true">
                    <button type="button" class="user-profile-secondary-btn" id="profile-photo-pick">
                        <i class="fa fa-camera" aria-hidden="true"></i>
                        Choose photo
                    </button>
                    <p class="user-profile-help">Square profile photo, max 5MB.</p>

                    <div id="profile-crop-panel" class="profile-crop-panel" hidden>
                        <canvas id="profile-crop-canvas" width="300" height="300" aria-label="Square crop preview"></canvas>
                        <label class="profile-zoom-label" for="profile-photo-zoom">Zoom</label>
                        <input id="profile-photo-zoom" type="range" min="100" max="260" value="100">
                        <button type="button" class="user-profile-primary-btn user-profile-full-btn" id="profile-photo-save">
                            Save photo
                        </button>
                    </div>
                </div>

                <form id="user-profile-form" class="user-profile-form">
                    <label class="user-profile-field" for="profile-name">
                        <span>Username</span>
                        <input id="profile-name" name="name" type="text" maxlength="25" value="@userName" required>
                    </label>

                    <label class="user-profile-field" for="profile-email">
                        <span>Email address</span>
                        <input id="profile-email" name="email" type="email" value="@userEmail" readonly>
                    </label>

                    <div class="user-profile-section">
                        <span class="user-profile-section-title">Order confirmation</span>

                        <label class="user-profile-field" for="profile-full-name">
                            <span>Full name</span>
                            <input id="profile-full-name" name="fullName" type="text" maxlength="120" autocomplete="name">
                        </label>

                        <label class="user-profile-field" for="profile-phone-number">
                            <span>Phone number</span>
                            <input id="profile-phone-number" name="phoneNumber" type="tel" maxlength="30" autocomplete="tel">
                        </label>

                        <label class="user-profile-field" for="profile-address-line-1">
                            <span>Address line 1</span>
                            <input id="profile-address-line-1" name="addressLine1" type="text" maxlength="180" autocomplete="address-line1">
                        </label>

                        <label class="user-profile-field" for="profile-address-line-2">
                            <span>Address line 2</span>
                            <input id="profile-address-line-2" name="addressLine2" type="text" maxlength="180" autocomplete="address-line2">
                        </label>

                        <div class="user-profile-field-row">
                            <label class="user-profile-field" for="profile-country">
                                <span>Country</span>
                                <input id="profile-country" name="country" type="text" maxlength="80" autocomplete="country-name">
                            </label>

                            <label class="user-profile-field" for="profile-city">
                                <span>City</span>
                                <input id="profile-city" name="city" type="text" maxlength="80" autocomplete="address-level2">
                            </label>
                        </div>
                    </div>

                    <div class="user-profile-action-row">
                        <div>
                            <strong>Password</strong>
                            <span>Send a reset link to your email.</span>
                        </div>
                        <button type="button" class="user-profile-secondary-btn" id="profile-password-reset">
                            <i class="fa fa-envelope-o" aria-hidden="true"></i>
                            Send link
                        </button>
                    </div>

                    <label class="user-profile-toggle">
                        <input id="profile-two-factor" type="checkbox" name="twoFactorEnabled">
                        <span class="user-profile-toggle-ui"></span>
                        <span>
                            <strong>Two-factor authentication</strong>
                            <em>Email code required for account access.</em>
                        </span>
                    </label>

                    <div id="profile-two-factor-confirm" class="user-profile-confirm-panel" hidden>
                        <label class="user-profile-field" for="profile-two-factor-code">
                            <span>Email verification code</span>
                            <input id="profile-two-factor-code" type="text" inputmode="numeric" maxlength="6" autocomplete="one-time-code" placeholder="000000">
                        </label>
                        <button type="button" class="user-profile-primary-btn user-profile-full-btn" id="profile-two-factor-confirm-btn">
                            Confirm 2FA change
                        </button>
                    </div>
                </form>
            </div>

            <div class="user-profile-modal-footer">
                <button type="button" class="user-profile-secondary-btn" data-profile-close>Close</button>
                <button type="submit" class="user-profile-primary-btn" form="user-profile-form">Save changes</button>
            </div>
        </section>
    </div>
}
