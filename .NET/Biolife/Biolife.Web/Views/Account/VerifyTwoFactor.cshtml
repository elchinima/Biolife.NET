@model TwoFactorLoginVm
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Two-Factor Verification";
}

<div class="login-bg">
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
</div>

<div class="login-wrapper">
    <div class="login-brand">
        <span class="logo-text">Biolife<span>Panel</span></span>
        <span class="brand-sub" style="margin-left: 10px;">Email verification</span>
    </div>

    <div class="login-card">
        <div class="login-card-header">
            <div class="login-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16v16H4z" />
                    <path d="M22 6 12 13 2 6" />
                </svg>
            </div>
            <h2 class="login-title">Check your email</h2>
            <p class="login-subtitle">Enter the 6-digit code sent to @Model.Email</p>
        </div>

        <form asp-action="VerifyTwoFactor" method="post" class="login-form">
            @if (TempData["Success"] is string successMessage)
            {
                <div style="font-size:13px; line-height:1.45; color:#6f8f32; margin-bottom:14px;">
                    @successMessage
                </div>
            }
            @if (TempData["Error"] is string errorMessage)
            {
                <div style="font-size:13px; line-height:1.45; color:#c44a32; margin-bottom:14px;">
                    @errorMessage
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:12px; margin-bottom:4px;"></div>

            <input asp-for="UserId" type="hidden" />
            <input asp-for="RememberMe" type="hidden" />
            <input asp-for="Email" type="hidden" />

            <div class="form-group">
                <label asp-for="Code">Verification code</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2v20" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </span>
                    <input asp-for="Code" class="form-input" placeholder="000000" autocomplete="one-time-code" inputmode="numeric" maxlength="6" />
                </div>
                <span asp-validation-for="Code" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" class="btn-login">
                <span class="btn-text">Verify and Sign In</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </button>
        </form>

        <form asp-action="ResendTwoFactorCode" method="post" style="margin-top:12px;">
            <input type="hidden" name="userId" value="@Model.UserId" />
            <input type="hidden" name="rememberMe" value="@Model.RememberMe.ToString().ToLowerInvariant()" />
            <button type="submit" class="btn-google" style="width:100%; justify-content:center;">
                <span>Send a new code</span>
            </button>
        </form>
    </div>

    <p class="login-footer">Biolife &copy; 2026. All rights reserved.</p>
</div>
