@model RegisterVm
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Register";
    var isGoogleAuthConfigured = ViewBag.IsGoogleAuthConfigured as bool? == true;
}

<div class="login-bg">
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
</div>

<div class="login-wrapper">

    <div class="login-brand">
        <span class="logo-text">Login<span>Panel</span></span>
        <span class="brand-sub" style="margin-left: 10px;">Secure management system</span>
    </div>

    <div class="login-card">
        <div class="login-card-header">
            <div class="login-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </div>
            <h2 class="login-title">Register</h2>
            <p class="login-subtitle">Fill in the details to create an account</p>
        </div>

        <form asp-action="Register" method="post" class="login-form" id="registerForm">
            <input asp-for="LocalCartJson" type="hidden" id="localCartJson" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:12px; margin-bottom:4px;"></div>

            <div class="form-group">
                <label asp-for="Name">
                    Full Name
                    <span class="name-limit-message" id="nameLimitMessage">Max 25 characters.</span>
                </label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </span>
                    <input asp-for="Name" class="form-input" placeholder="Your name" autocomplete="name" maxlength="25" data-name-max-length="25" data-limit-message="#nameLimitMessage" />
                </div>
                <span asp-validation-for="Name" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </span>
                    <input asp-for="Email" class="form-input" placeholder="you@example.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="Password" class="form-input" placeholder="Password" autocomplete="new-password" />
                    <button type="button" class="password-toggle" id="passwordToggle">
                        <svg class="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="ConfirmPassword" class="form-input" placeholder="Confirm password" autocomplete="new-password" />
                    <button type="button" class="password-toggle" id="confirmPasswordToggle">
                        <svg class="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" class="btn-login">
                <span class="btn-text">Create Account</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </button>

            <div class="auth-divider"><span>or</span></div>

            @if (isGoogleAuthConfigured)
            {
                <a asp-action="GoogleLogin" class="btn-google">
                    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M21.8 12.2c0-.7-.1-1.4-.2-2H12v3.8h5.5c-.2 1.2-1 2.3-2.1 3v2.5h3.4c2-1.9 3-4.6 3-7.3z" />
                        <path fill="#34A853" d="M12 22c2.8 0 5.1-.9 6.8-2.5L15.4 17c-.9.6-2.1 1-3.4 1-2.6 0-4.9-1.8-5.7-4.2H2.8v2.6C4.5 19.7 7.9 22 12 22z" />
                        <path fill="#FBBC05" d="M6.3 13.8c-.2-.6-.3-1.2-.3-1.8s.1-1.2.3-1.8V7.6H2.8C2.1 8.9 1.8 10.4 1.8 12s.4 3.1 1 4.4l3.5-2.6z" />
                        <path fill="#EA4335" d="M12 6c1.5 0 2.8.5 3.9 1.5l2.9-2.9C17.1 3 14.8 2 12 2 7.9 2 4.5 4.3 2.8 7.6l3.5 2.6C7.1 7.8 9.4 6 12 6z" />
                    </svg>
                    <span>Sign up with Google</span>
                </a>
            }
            else
            {
                <button type="button" class="btn-google is-disabled" disabled>
                    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M21.8 12.2c0-.7-.1-1.4-.2-2H12v3.8h5.5c-.2 1.2-1 2.3-2.1 3v2.5h3.4c2-1.9 3-4.6 3-7.3z" />
                        <path fill="#34A853" d="M12 22c2.8 0 5.1-.9 6.8-2.5L15.4 17c-.9.6-2.1 1-3.4 1-2.6 0-4.9-1.8-5.7-4.2H2.8v2.6C4.5 19.7 7.9 22 12 22z" />
                        <path fill="#FBBC05" d="M6.3 13.8c-.2-.6-.3-1.2-.3-1.8s.1-1.2.3-1.8V7.6H2.8C2.1 8.9 1.8 10.4 1.8 12s.4 3.1 1 4.4l3.5-2.6z" />
                        <path fill="#EA4335" d="M12 6c1.5 0 2.8.5 3.9 1.5l2.9-2.9C17.1 3 14.8 2 12 2 7.9 2 4.5 4.3 2.8 7.6l3.5 2.6C7.1 7.8 9.4 6 12 6z" />
                    </svg>
                    <span>Sign up with Google</span>
                </button>
            }

            <p style="text-align:center; font-size:12px; color:#aaa; margin-top:4px;">
                Already have an account?
                <a asp-action="Login" style="color: var(--green); font-weight:600; text-decoration:none;">Sign In</a>
            </p>
        </form>
    </div>

    <p class="login-footer">Biolife &copy; 2026. All rights reserved.</p>
</div>

<script>
    const setupToggle = (toggleId, inputSelector) => {
        const toggle = document.getElementById(toggleId);
        const pwdInput = document.querySelector(inputSelector);

        if (!toggle || !pwdInput) {
            return;
        }

        const eyeOpen = toggle.querySelector('.eye-open');
        const eyeClosed = toggle.querySelector('.eye-closed');

        toggle.addEventListener('click', () => {
            const isText = pwdInput.type === 'text';
            pwdInput.type = isText ? 'password' : 'text';
            if (eyeOpen) {
                eyeOpen.style.display = isText ? '' : 'none';
            }
            if (eyeClosed) {
                eyeClosed.style.display = isText ? 'none' : '';
            }
        });
    };

    setupToggle('passwordToggle', 'input[name="Password"]');
    setupToggle('confirmPasswordToggle', 'input[name="ConfirmPassword"]');

    const registerForm = document.getElementById('registerForm');
    const localCartJson = document.getElementById('localCartJson');

    if (registerForm && localCartJson) {
        registerForm.addEventListener('submit', () => {
            localCartJson.value = localStorage.getItem('biolife.cart.v1') || '[]';
        });
    }

</script>
