@model ResetPasswordVm
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Reset Password";
}

<div class="login-bg">
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
</div>

<div class="login-wrapper">

    <div class="login-brand">
        <span class="logo-text">Reset<span>Panel</span></span>
        <p class="brand-sub">Choose a new password</p>
    </div>

    <div class="login-card">
        <div class="login-card-header">
            <div class="login-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            <h2 class="login-title">Reset Password</h2>
            <p class="login-subtitle">Create a new password for your account</p>
        </div>

        <form asp-action="ResetPassword" method="post" class="login-form">
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:12px; margin-bottom:4px;"></div>

            <div class="form-group">
                <label asp-for="Password">New Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="Password" class="form-input" placeholder="New password" autocomplete="new-password" />
                    <button type="button" class="password-toggle" id="passwordToggle">
                        <svg class="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm New Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="ConfirmPassword" class="form-input" placeholder="Confirm password" autocomplete="new-password" />
                    <button type="button" class="password-toggle" id="confirmPasswordToggle">
                        <svg class="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 0 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" class="btn-login">
                <span class="btn-text">Change Password</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </button>
        </form>
    </div>

    <p class="login-footer">Biolife &copy; 2026. All rights reserved.</p>
</div>

<script>
    const setupToggle = (toggleId, inputSelector) => {
        const toggle = document.getElementById(toggleId);
        const pwdInput = document.querySelector(inputSelector);

        if (!toggle || !pwdInput) {
            return;
        }

        const eyeOpen = toggle.querySelector('.eye-open');
        const eyeClosed = toggle.querySelector('.eye-closed');

        toggle.addEventListener('click', () => {
            const isText = pwdInput.type === 'text';
            pwdInput.type = isText ? 'password' : 'text';
            if (eyeOpen) {
                eyeOpen.style.display = isText ? '' : 'none';
            }
            if (eyeClosed) {
                eyeClosed.style.display = isText ? 'none' : '';
            }
        });
    };

    setupToggle('passwordToggle', 'input[name="Password"]');
    setupToggle('confirmPasswordToggle', 'input[name="ConfirmPassword"]');
</script>
