@model ForgotPasswordVm
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<div class="login-bg">
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
</div>

<div class="login-wrapper">

    <div class="login-brand">
        <span class="logo-text">Reset<span>Panel</span></span>
        <p class="brand-sub">Recover your account</p>
    </div>

    <div class="login-card">
        <div class="login-card-header">
            <div class="login-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
            </div>
            <h2 class="login-title">Forgot Password</h2>
            <p class="login-subtitle">Enter your email to receive a reset link</p>
        </div>

        <form asp-action="ForgotPassword" method="post" class="login-form">
            @if (TempData["Error"] is string errorMessage)
            {
                <div style="font-size:13px; line-height:1.45; color:#dc3545; margin-bottom:14px;">
                    @errorMessage
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:12px; margin-bottom:4px;"></div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </span>
                    <input asp-for="Email" class="form-input" placeholder="you@example.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" class="btn-login">
                <span class="btn-text">Send Reset Link</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </button>

            <p style="text-align:center; font-size:12px; color:#aaa; margin-top:4px;">
                Remembered your password?
                <a asp-action="Login" style="color: var(--green); font-weight:600; text-decoration:none;">Sign In</a>
            </p>
        </form>
    </div>

    <p class="login-footer">Biolife &copy; 2026. All rights reserved.</p>
</div>
