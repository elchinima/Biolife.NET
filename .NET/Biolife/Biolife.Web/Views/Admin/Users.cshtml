@model Biolife.Application.ViewModels.AdminVm
@{
    Layout = null;
    var role = Model.CurrentUserRole;
    var currentAdminName = User.Identity?.Name;
    if (string.IsNullOrWhiteSpace(currentAdminName))
    {
        currentAdminName = "Admin";
    }
    var currentAdminInitial = currentAdminName.Substring(0, 1).ToUpperInvariant();
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}
@functions {
    private static string NormalizeHexColor(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "#888888";

        var value = color.Trim();
        if (!value.StartsWith("#"))
            value = "#" + value;

        if (value.Length == 4)
            value = $"#{value[1]}{value[1]}{value[2]}{value[2]}{value[3]}{value[3]}";

        if (value.Length != 7)
            return "#888888";

        return System.Text.RegularExpressions.Regex.IsMatch(value, "^#[0-9A-Fa-f]{6}$")
            ? value
            : "#888888";
    }

    private static string GetContrastColor(string backgroundColor)
    {
        var r = Convert.ToInt32(backgroundColor.Substring(1, 2), 16);
        var g = Convert.ToInt32(backgroundColor.Substring(3, 2), 16);
        var b = Convert.ToInt32(backgroundColor.Substring(5, 2), 16);
        var brightness = (r * 299 + g * 587 + b * 114) / 1000;
        return brightness >= 140 ? "#111111" : "#ffffff";
    }

    private static int? GetHighestRoleSortOrder(User user)
    {
        var sortOrderFromMany = (user.UserRoles ?? Enumerable.Empty<UserRole>())
            .Where(ur => ur.Role != null)
            .Select(ur => (int?)ur.Role!.SortOrder)
            .OrderBy(x => x)
            .FirstOrDefault();

        if (sortOrderFromMany.HasValue)
            return sortOrderFromMany.Value;

        return user.Role?.SortOrder;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel.css">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel_responsive.css">
    <style>
        .user-dropdown form {
            margin: 0;
        }

        .user-dropdown .dropdown-action {
            width: 100%;
            border: none;
            background: none;
            text-align: left;
            padding: 9px 14px;
            font-size: 12px;
            color: #444;
            font-family: "Montserrat", sans-serif;
            cursor: pointer;
            transition: background 0.15s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-dropdown .dropdown-action:hover {
            background: #f5f5f5;
        }

        .user-dropdown .disabled-action {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 14px;
            font-size: 12px;
            color: #a8a8a8;
            cursor: not-allowed;
        }

        .more-roles-badge {
            cursor: help;
        }
    </style>
</head>
<body data-can-products="@(role?.Products == true ? "true" : "false")"
      data-can-slider="@(role?.Slider == true ? "true" : "false")"
      data-can-authors="@(role?.Author == true ? "true" : "false")"
      data-can-genres="@(role?.Genres == true ? "true" : "false")"
      data-can-users="@(role?.Users == true ? "true" : "false")"
      data-can-roles="@(role?.Roles == true ? "true" : "false")"
      data-can-create-notes="@(role?.CreateNotes == true ? "true" : "false")">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo"><span class="logo-text">Admin<span>Panel</span></span></div>
        <nav class="sidebar-nav">
            <a href="/Admin/Index" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span>Dashboard</span>
            </a>
            <a href="/Admin/Products" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <span>Products</span>
            </a>
            <a href="/Admin/Carousel" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><polyline points="16 2 12 7 8 2" /></svg>
                <span>Slider</span>
            </a>
            <a href="/Admin/Authors" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="16" y1="11" x2="22" y2="11" /></svg>
                <span>Authors</span>
            </a>
            <a href="/Admin/Genres" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M3 12h18" /><path d="M3 18h18" /></svg>
                <span>Genres</span>
            </a>
            <a href="/Admin/Users" class="nav-item active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                <span>Users</span>
            </a>
            <a href="/Admin/Roles" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l7 4v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-4z" />
                </svg>
                <span>Roles</span>
            </a>
            <a href="/Admin/Notes" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16v16H4z" />
                    <path d="M8 8h8" />
                    <path d="M8 12h8" />
                    <path d="M8 16h5" />
                </svg>
                <span>Notes</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/" class="nav-item nav-logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                <span>Exit to site</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            </button>
            <h1 class="page-title">Users</h1>
            <div class="topbar-right">
                <span class="topbar-date" id="topbarDate"></span>
                <div class="topbar-user">
                    <div class="user-avatar">@currentAdminInitial</div>
                    <span>@currentAdminName</span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="page-actions">
                <div class="search-bar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" id="userSearch" placeholder="Search users...">
                </div>
                <select class="filter-select" id="statusFilter">
                    <option value="">All Status</option>
                    <option value="true">Active</option>
                    <option value="false">Blocked</option>
                </select>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3>Users <span style="color:#aaa; font-weight:500;">(@Model.TotalUsers)</span></h3>
                </div>
                <table class="data-table" id="usersTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Registered</th>
                            <th>Last Login</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var actorUserId = int.TryParse(currentUserId, out var parsedCurrentUserId)
                                ? parsedCurrentUserId
                                : (int?)null;

                            var actorUser = actorUserId.HasValue
                                ? Model.Users.FirstOrDefault(u => u.Id == actorUserId.Value)
                                : null;

                            var actorHighestSortOrder = actorUser != null
                                ? GetHighestRoleSortOrder(actorUser)
                                : null;
                        }
                        @foreach (var user in Model.Users)
                        {
                            var assignedRoles = user.UserRoles
                                .Where(ur => ur.Role != null)
                                .Select(ur => ur.Role!)
                                .DistinctBy(r => r.Id)
                                .OrderBy(r => r.SortOrder)
                                .ThenBy(r => r.Id)
                                .ToList();

                            if (assignedRoles.Count == 0 && user.Role != null)
                                assignedRoles.Add(user.Role);

                            var highestRole = assignedRoles.FirstOrDefault();
                            var extraRolesCount = Math.Max(0, assignedRoles.Count - 1);
                            var extraRolesText = string.Join(", ", assignedRoles.Skip(1).Select(r => r.Name));
                            var roleColor = NormalizeHexColor(highestRole?.Color);
                            var roleTextColor = GetContrastColor(roleColor);
                            var isCurrentUser = currentUserId == user.Id.ToString();
                            var targetHighestSortOrder = GetHighestRoleSortOrder(user);
                            var canManageTarget = isCurrentUser
                                || actorHighestSortOrder == null
                                || targetHighestSortOrder == null
                                || actorHighestSortOrder < targetHighestSortOrder;

                            <tr data-status="@user.IsActive.ToString().ToLower()">
                                <td style="color:#aaa;">#@user.Id</td>
                                <td style="font-weight:600;">@user.Name</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge" style="background:@roleColor; color:@roleTextColor;">
                                        @(highestRole?.Name ?? "No role")
                                    </span>
                                    @if (extraRolesCount > 0)
                                    {
                                        <span class="badge badge-info more-roles-badge" style="margin-left:6px;" title="@extraRolesText">+@extraRolesCount</span>
                                    }
                                </td>
                                <td>@user.CreatedAt.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</td>
                                <td>
                                    @if (user.LastLogin.HasValue)
                                    {
                                        @user.LastLogin.Value.ToString("dd MMM yyyy, HH:mm", System.Globalization.CultureInfo.InvariantCulture)
                                    }
                                    else
                                    {
                                        <span style="color:#ccc;">Never</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Blocked</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <div class="dropdown-wrapper">
                                            <button class="btn-icon" title="Actions" onclick="toggleUserMenu(@user.Id)">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                    <circle cx="12" cy="5" r="1.5" />
                                                    <circle cx="12" cy="12" r="1.5" />
                                                    <circle cx="12" cy="19" r="1.5" />
                                                </svg>
                                            </button>
                                            <div class="user-dropdown" id="menu-@user.Id">
                                                @if (canManageTarget)
                                                {
                                                    <a href="#" onclick="openChangeName(@user.Id, '@Html.Raw((user.Name ?? string.Empty).Replace("'", "\\'"))'); return false;">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <path d="M12 20h9" />
                                                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                                                        </svg>
                                                        <span>Change Name</span>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="disabled-action">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <path d="M12 20h9" />
                                                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                                                        </svg>
                                                        <span>Change Name</span>
                                                    </span>
                                                }
                                                @if (isCurrentUser || !canManageTarget)
                                                {
                                                    <span class="disabled-action">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <rect x="3" y="11" width="18" height="10" rx="2" />
                                                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                                        </svg>
                                                        <span>@(isCurrentUser ? "Block" : "Blocked by hierarchy")</span>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <form method="post" action="/Admin/ToggleUserBlock">
                                                        <input type="hidden" name="id" value="@user.Id">
                                                        <button type="submit" class="dropdown-action">
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                @if (user.IsActive)
                                                                {
                                                                    <rect x="3" y="11" width="18" height="10" rx="2" />
                                                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                                                }
                                                                else
                                                                {
                                                                    <rect x="3" y="11" width="18" height="10" rx="2" />
                                                                    <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                                                                }
                                                            </svg>
                                                            <span>@(user.IsActive ? "Block" : "Unblock")</span>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <div class="modal-overlay" id="changeNameModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h3>Change User Name</h3>
                <button class="modal-close" onclick="document.getElementById('changeNameModal').classList.remove('open')">&#10005;</button>
            </div>
            <form method="post" action="/Admin/UpdateUserName">
                <div class="modal-body">
                    <input type="hidden" name="id" id="changeNameUserId">
                    <div class="form-group">
                        <label>Name *</label>
                        <input type="text" name="name" id="changeNameInput" class="form-input" maxlength="60" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="document.getElementById('changeNameModal').classList.remove('open')">Cancel</button>
                    <button type="submit" class="btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>

    <script defer src="~/admin/Script/admin_panel.js"></script>
    <script>
        function toggleUserMenu(id) {
        document.querySelectorAll('.user-dropdown').forEach(m => {
        if (m.id !== 'menu-' + id) m.classList.remove('open');
        });
        document.getElementById('menu-' + id).classList.toggle('open');
        }

        function openChangeName(id, name) {
        document.getElementById('changeNameUserId').value = id;
        document.getElementById('changeNameInput').value = name || '';
        document.querySelectorAll('.user-dropdown').forEach(m => m.classList.remove('open'));
        document.getElementById('changeNameModal').classList.add('open');
        }

        document.addEventListener('click', function (e) {
        if (!e.target.closest('.actions-cell'))
        document.querySelectorAll('.user-dropdown').forEach(m => m.classList.remove('open'));
        });

        document.getElementById('userSearch').addEventListener('input', filterTable);
        document.getElementById('statusFilter').addEventListener('change', filterTable);

        function filterTable() {
        const search = document.getElementById('userSearch').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        document.querySelectorAll('#usersTable tbody tr').forEach(row => {
        const text = row.textContent.toLowerCase();
        const rowStatus = row.dataset.status;
        const matchSearch = text.includes(search);
        const matchStatus = status === '' || rowStatus === status;
        row.style.display = matchSearch && matchStatus ? '' : 'none';
        });
        }
    </script>
</body>
</html>
