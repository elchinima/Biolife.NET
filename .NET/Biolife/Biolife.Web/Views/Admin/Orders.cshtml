@model Biolife.Application.ViewModels.AdminVm
@{
    Layout = null;
    var role = Model.CurrentUserRole;
    var currentAdminName = User.Identity?.Name;
    if (string.IsNullOrWhiteSpace(currentAdminName))
    {
        currentAdminName = "Admin";
    }
    var currentAdminInitial = currentAdminName.Substring(0, 1).ToUpperInvariant();
    var orderStatuses = new[] { "Pending", "Processing", "Shipped", "Completed", "Cancelled" };
}
@functions {
    private static string GetOrderStatusClass(string? status)
    {
        return (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "processing" => "status-info",
            "shipped" => "status-warning",
            "completed" => "status-success",
            "cancelled" => "status-danger",
            _ => "status-pending"
        };
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel.css">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel_responsive.css">
</head>
<body data-can-products="@(role?.Products == true ? "true" : "false")"
      data-can-slider="@(role?.Slider == true ? "true" : "false")"
      data-can-tags="@(role?.Tag == true ? "true" : "false")"
      data-can-genres="@(role?.Genres == true ? "true" : "false")"
      data-can-users="@(role?.Users == true ? "true" : "false")"
      data-can-roles="@(role?.Roles == true ? "true" : "false")"
      data-can-create-notes="@(role?.CreateNotes == true ? "true" : "false")"
      data-can-orders="@(role?.Orders == true ? "true" : "false")">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo"><span class="logo-text">Admin<span>Panel</span></span></div>
        <nav class="sidebar-nav">
            <a href="/Admin/Index" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span>Dashboard</span>
            </a>
            <a href="/Admin/Products" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <span>Products</span>
            </a>
            <a href="/Admin/Carousel" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><polyline points="16 2 12 7 8 2" /></svg>
                <span>Slider</span>
            </a>
            <a href="/Admin/Tags" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="16" y1="11" x2="22" y2="11" /></svg>
                <span>Tags</span>
            </a>
            <a href="/Admin/Genres" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M3 12h18" /><path d="M3 18h18" /></svg>
                <span>Genres</span>
            </a>
            <a href="/Admin/Users" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                <span>Users</span>
            </a>
            <a href="/Admin/Roles" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-4z" /></svg>
                <span>Roles</span>
            </a>
            <a href="/Admin/Notes" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z" /><path d="M8 8h8" /><path d="M8 12h8" /><path d="M8 16h5" /></svg>
                <span>Notes</span>
            </a>
            <a href="/Admin/Orders" class="nav-item active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><path d="M3 6h18" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                <span>Orders</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/" class="nav-item nav-logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                <span>Exit to site</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            </button>
            <h1 class="page-title">Orders</h1>
            <div class="topbar-right">
                <span class="topbar-date" id="topbarDate"></span>
                <div class="topbar-user">
                    <div class="user-avatar">@currentAdminInitial</div>
                    <span>@currentAdminName</span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="stats-grid orders-stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><path d="M3 6h18" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Total Orders</span>
                        <strong class="stat-value">@Model.TotalOrders</strong>
                        <span class="stat-trend neutral">All time</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Revenue</span>
                        <strong class="stat-value">@Model.TotalRevenue.ToString("N2") &#8380;</strong>
                        <span class="stat-trend neutral">Completed and active orders</span>
                    </div>
                </div>
            </div>

            <div class="page-actions">
                <div class="search-bar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" id="orderSearch" placeholder="Search orders...">
                </div>
                <select class="filter-select" id="orderStatusFilter">
                    <option value="">All Status</option>
                    @foreach (var status in orderStatuses)
                    {
                        <option value="@status.ToLowerInvariant()">@status</option>
                    }
                </select>
            </div>

            <div class="card orders-table-card">
                <div class="card-header">
                    <h3>Orders <span style="color:#aaa; font-weight:500;">(@Model.TotalOrders)</span></h3>
                </div>
                <table class="data-table orders-table" id="ordersTable">
                    <colgroup>
                        <col class="order-col-id">
                        <col class="order-col-customer">
                        <col class="order-col-contacts">
                        <col class="order-col-address">
                        <col class="order-col-items">
                        <col class="order-col-total">
                        <col class="order-col-created">
                        <col class="order-col-status">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Contacts</th>
                            <th>Address</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Created</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            var normalizedStatus = (order.Status ?? "Pending").Trim();
                            <tr data-status="@normalizedStatus.ToLowerInvariant()">
                                <td class="order-id-cell">#@order.Id</td>
                                <td class="order-truncate-cell">
                                    <strong class="order-line">@order.FullName</strong>
                                    <span class="order-muted order-line">@order.User?.Name</span>
                                </td>
                                <td class="order-truncate-cell">
                                    <span class="order-line">@order.Email</span>
                                    <span class="order-muted order-line">@order.PhoneNumber</span>
                                </td>
                                <td class="order-truncate-cell">
                                    <span class="order-line">@order.AddressLine1</span>
                                    @if (!string.IsNullOrWhiteSpace(order.AddressLine2))
                                    {
                                        <span class="order-muted order-line">@order.AddressLine2</span>
                                    }
                                    <span class="order-muted order-line">@order.City, @order.Country</span>
                                </td>
                                <td class="order-truncate-cell">
                                    <div class="order-items-list">
                                        @foreach (var item in order.Items)
                                        {
                                            <span class="order-line">@item.ProductName x @item.Quantity</span>
                                        }
                                    </div>
                                </td>
                                <td class="order-total-cell"><strong>&#8380; @order.Subtotal.ToString("N2")</strong></td>
                                <td class="order-created-cell">@order.CreatedAt.ToString("dd MMM yyyy, HH:mm", System.Globalization.CultureInfo.InvariantCulture)</td>
                                <td>
                                    <form method="post" action="/Admin/UpdateOrderStatus" class="order-status-form">
                                        <input type="hidden" name="id" value="@order.Id">
                                        <select name="status" class="status-select @GetOrderStatusClass(normalizedStatus)" onchange="this.form.submit()">
                                            @foreach (var status in orderStatuses)
                                            {
                                                if (status == normalizedStatus)
                                                {
                                                    <option value="@status" selected>@status</option>
                                                }
                                                else
                                                {
                                                    <option value="@status">@status</option>
                                                }
                                            }
                                        </select>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script defer src="~/admin/Script/admin_panel.js"></script>
    <script>
        const orderSearch = document.getElementById('orderSearch');
        const orderStatusFilter = document.getElementById('orderStatusFilter');

        function filterOrders() {
            const search = (orderSearch.value || '').toLowerCase();
            const status = orderStatusFilter.value;
            document.querySelectorAll('#ordersTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                const rowStatus = row.dataset.status;
                const matchSearch = text.includes(search);
                const matchStatus = status === '' || rowStatus === status;
                row.style.display = matchSearch && matchStatus ? '' : 'none';
            });
        }

        orderSearch.addEventListener('input', filterOrders);
        orderStatusFilter.addEventListener('change', filterOrders);
    </script>
</body>
</html>

