@model Biolife.Application.ViewModels.AdminVm
@{
    Layout = null;
    var role = Model.CurrentUserRole;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carousel - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel.css">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel_responsive.css">
</head>
<body data-can-products="@(role?.Products == true ? "true" : "false")"
      data-can-slider="@(role?.Slider == true ? "true" : "false")"
      data-can-authors="@(role?.Author == true ? "true" : "false")"
      data-can-genres="@(role?.Genres == true ? "true" : "false")"
      data-can-users="@(role?.Users == true ? "true" : "false")"
      data-can-roles="@(role?.Roles == true ? "true" : "false")"
      data-can-create-notes="@(role?.CreateNotes == true ? "true" : "false")">

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <span class="logo-text">Admin<span>Panel</span></span>
        </div>
        <nav class="sidebar-nav">
            <a href="/Admin/Index" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span>Dashboard</span>
            </a>
            <a href="/Admin/Products" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <span>Products</span>
            </a>
            <a href="/Admin/Carousel" class="nav-item active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><polyline points="16 2 12 7 8 2" /></svg>
                <span>Slider</span>
            </a>
            <a href="/Admin/Authors" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="16" y1="11" x2="22" y2="11" /></svg>
                <span>Authors</span>
            </a>
            <a href="/Admin/Genres" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M3 12h18" /><path d="M3 18h18" /></svg>
                <span>Genres</span>
            </a>
            <a href="/Admin/Users" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                <span>Users</span>
            </a>
            <a href="/Admin/Roles" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l7 4v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-4z" />
                </svg>
                <span>Roles</span>
            </a>
            <a href="/Admin/Notes" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16v16H4z" />
                    <path d="M8 8h8" />
                    <path d="M8 12h8" />
                    <path d="M8 16h5" />
                </svg>
                <span>Notes</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/" class="nav-item nav-logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                <span>Exit to site</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            </button>
            <h1 class="page-title">Slider</h1>
            <div class="topbar-right">
                <span class="topbar-date" id="topbarDate"></span>
                <div class="topbar-user">
                    <div class="user-avatar">@((!string.IsNullOrWhiteSpace(User.Identity?.Name) ? User.Identity.Name!.Substring(0, 1).ToUpperInvariant() : "A"))</div>
                    <span>@(string.IsNullOrWhiteSpace(User.Identity?.Name) ? "Admin" : User.Identity!.Name)</span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="page-actions">
                <button class="btn-primary" onclick="document.getElementById('addSlideModal').classList.add('open')">+ Add Slide</button>
            </div>

            <div class="slides-grid">
                @foreach (var slide in Model.Carousels)
                {
                    <div class="slide-card">
                        <div class="slide-preview image-hover-wrap" style="background: linear-gradient(135deg, #e8f5d9 60%, #b8dda0 100%); @(!string.IsNullOrEmpty(slide.ImageUrl) ? $"background-image:url({slide.ImageUrl});background-size:cover;background-position:center;" : "")">
                            <span class="slide-num">Slide #@slide.Order</span>
                            <div class="slide-mock-text">
                                <div class="mock-line" style="width:70%"></div>
                                <div class="mock-line" style="width:50%"></div>
                            </div>
                            @if (!string.IsNullOrEmpty(slide.ImageUrl))
                            {
                                <div class="image-hover-popover">
                                    <img src="@slide.ImageUrl" alt="@slide.Name">
                                </div>
                            }
                        </div>
                        <div class="slide-card-body">
                            <form method="post" action="/Admin/UpdateCarousel" enctype="multipart/form-data">
                                <input type="hidden" name="Id" value="@slide.Id">
                                <div class="form-group">
                                    <label>Title</label>
                                    <input type="text" name="Name" class="form-input" value="@slide.Name">
                                </div>
                                <div class="form-group">
                                    <label>Description</label>
                                    <input type="text" name="Decription" class="form-input" value="@slide.Decription">
                                </div>
                                <div class="form-group">
                                    <label>Button Text</label>
                                    <input type="text" name="ButtonText" class="form-input" value="@slide.ButtonText">
                                </div>
                                <div class="form-group">
                                    <label>Button Link</label>
                                    <input type="text" name="ButtonLink" class="form-input" value="@slide.ButtonLink">
                                </div>
                                <div class="form-group">
                                    <label>Order</label>
                                    <input type="number" name="Order" class="form-input" value="@slide.Order">
                                </div>
                                <div class="form-group" style="display:flex;align-items:center;gap:10px">
                                    <input type="hidden" name="IsActive" value="false">
                                    <input type="checkbox" name="IsActive" value="true" @(slide.IsActive ? "checked" : "") id="isActive-@slide.Id">
                                    <label for="isActive-@slide.Id" style="margin:0">Active</label>
                                </div>
                                <div class="form-group">
                                    <label>Background Image</label>
                                    <div class="file-upload-area">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                                        <span class="file-upload-label">Upload Image</span>
                                        <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.gif">
                                    </div>
                                </div>
                                <div class="slide-actions">
                                    <button type="submit" class="btn-primary btn-sm">Save</button>
                                    <button type="button" class="btn-danger btn-sm btn-del" data-id="@slide.Id">Delete</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </main>
    </div>

    <div class="modal-overlay" id="addSlideModal">
        <div class="modal">
            <div class="modal-header">
                <h3>Add Slide</h3>
                <button class="modal-close" onclick="document.getElementById('addSlideModal').classList.remove('open')">&#10005;</button>
            </div>
            <form method="post" action="/Admin/CreateCarousel" enctype="multipart/form-data">
                <div class="modal-body">
                    <div asp-validation-summary="All" class="validation-summary"></div>
                    <div class="form-group">
                        <label>Title *</label>
                        <input type="text" name="Name" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <input type="text" name="Decription" class="form-input" value="">
                    </div>
                    <div class="form-group">
                        <label>Button Text</label>
                        <input type="text" name="ButtonText" class="form-input">
                    </div>
                    <div class="form-group">
                        <label>Button Link</label>
                        <input type="text" name="ButtonLink" class="form-input" placeholder="/catalog">
                    </div>
                    <div class="form-group">
                        <label>Order</label>
                        <input type="number" name="Order" class="form-input" value="1">
                    </div>
                    <div class="form-group" style="display:flex;align-items:center;gap:10px">
                        <input type="hidden" name="IsActive" value="false">
                        <input type="checkbox" name="IsActive" value="true" id="addIsActive" checked>
                        <label for="addIsActive" style="margin:0">Active</label>
                    </div>
                    <div class="form-group">
                        <label>Background Image</label>
                        <div class="file-upload-area">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                            <span class="file-upload-label">Upload Image</span>
                            <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.gif">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="document.getElementById('addSlideModal').classList.remove('open')">Cancel</button>
                    <button type="submit" class="btn-primary">Add Slide</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="confirmModal">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h3>Confirm Deletion</h3>
                <button class="modal-close" onclick="document.getElementById('confirmModal').classList.remove('open')">&#10005;</button>
            </div>
            <div class="modal-body">
                <p style="font-size:14px;color:#555;line-height:1.6">Are you sure you want to delete this slide?</p>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="document.getElementById('confirmModal').classList.remove('open')">Cancel</button>
                <button class="btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>

    <form id="deleteSlideForm" method="post" action="/Admin/DeleteCarousel" style="display:none">
        <input type="hidden" name="id" id="deleteSlideId">
    </form>

    <script defer src="~/admin/Script/admin_panel.js"></script>
    <script>
        let pendingId = null;
        document.querySelectorAll('.btn-del').forEach(btn => {
            btn.addEventListener('click', () => {
                pendingId = btn.dataset.id;
                document.getElementById('confirmModal').classList.add('open');
            });
        });
        document.getElementById('confirmDeleteBtn')?.addEventListener('click', () => {
            if (pendingId) {
                document.getElementById('deleteSlideId').value = pendingId;
                document.getElementById('deleteSlideForm').submit();
            }
        });
    </script>
</body>
</html>
