<div class="main-wrapper">

    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
        </button>
        <h1 class="page-title" id="pageTitle">Dashboard</h1>
        <div class="topbar-right">
            <span class="topbar-date" id="topbarDate"></span>
            <div class="topbar-user">
                <div class="user-avatar">@((!string.IsNullOrWhiteSpace(User.Identity?.Name) ? User.Identity.Name!.Substring(0, 1).ToUpperInvariant() : "A"))</div>
                <span>@(string.IsNullOrWhiteSpace(User.Identity?.Name) ? "Admin" : User.Identity!.Name)</span>
            </div>
        </div>
    </header>

    <main class="content" id="mainContent">


        <div class="page active" id="page-dashboard">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                            <line x1="3" y1="6" x2="21" y2="6" />
                            <path d="M16 10a4 4 0 0 1-8 0" />
                        </svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Total Orders</span>
                        <strong class="stat-value">@Model.TotalProducts</strong>
                        <span class="stat-trend up">+12% this month</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Revenue</span>
                        <strong class="stat-value">@Model.TotalRevenue.ToString("N2") &#8380;</strong>
                        <span class="stat-trend up">+8% this month</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Books in Catalog</span>
                        <strong class="stat-value">@Model.TotalGenres (@Model.TotalAuthors authors)</strong>
                        <span class="stat-trend neutral">No changes</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Users</span>
                        <strong class="stat-value">@Model.TotalCarousels slides</strong>
                        <span class="stat-trend up">+34 today</span>
                    </div>
                </div>
            </div>


            <div class="dashboard-grid">
                <div class="card chart-card">
                    <div class="card-header">
                        <h3>Sales in the Last 7 Days</h3>
                    </div>
                    <div class="chart-area">
                        <svg class="bar-chart" viewBox="0 0 560 180" preserveAspectRatio="none">
                            <defs>
                                <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#05a503" />
                                    <stop offset="100%" stop-color="#7bd34f" />
                                </linearGradient>
                            </defs>

                            <line x1="0" y1="40" x2="560" y2="40" stroke="#f0f0f0" stroke-width="1" />
                            <line x1="0" y1="80" x2="560" y2="80" stroke="#f0f0f0" stroke-width="1" />
                            <line x1="0" y1="120" x2="560" y2="120" stroke="#f0f0f0" stroke-width="1" />
                            <line x1="0" y1="160" x2="560" y2="160" stroke="#f0f0f0" stroke-width="1" />

                            <rect class="bar" x="20" y="80" width="55" height="80" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="100" y="50" width="55" height="110" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="180" y="100" width="55" height="60" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="260" y="30" width="55" height="130" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="340" y="70" width="55" height="90" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="420" y="55" width="55" height="105" rx="3" fill="url(#barGrad)" />
                            <rect class="bar" x="500" y="20" width="55" height="140" rx="3" fill="#049202"
                                  opacity="1" />

                            <text x="47" y="175" text-anchor="middle" class="chart-label">Mon</text>
                            <text x="127" y="175" text-anchor="middle" class="chart-label">Tue</text>
                            <text x="207" y="175" text-anchor="middle" class="chart-label">Wed</text>
                            <text x="287" y="175" text-anchor="middle" class="chart-label">Thu</text>
                            <text x="367" y="175" text-anchor="middle" class="chart-label">Fri</text>
                            <text x="447" y="175" text-anchor="middle" class="chart-label">Sat</text>
                            <text x="527" y="175" text-anchor="middle" class="chart-label">Sun</text>
                        </svg>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3>Users</h3>
                    </div>
                    <table class="mini-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users.OrderBy(u => u.Id))
                            {
                                var highestRole = GetHighestRole(user);
                                var roleColor = NormalizeHexColor(highestRole?.Color);
                                var roleTextColor = GetContrastColor(roleColor);
                                <tr>
                                    <td>#@user.Id</td>
                                    <td>@user.Name</td>
                                    <td>
                                        <span class="badge" style="background:@roleColor; color:@roleTextColor;">
                                            @GetHighestRoleName(user)
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Blocked</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

            <div class="slides-grid" id="slidesGrid">
                @foreach (var slide in Model.Carousels)
                {
                    <div class="slide-card">
                        <div class="slide-preview image-hover-wrap" style="background: linear-gradient(135deg, #f0f7e6 60%, #c8e69a 100%); @(!string.IsNullOrEmpty(slide.ImageUrl) ? $"background-image:url({slide.ImageUrl});background-size:cover;background-position:center;" : "")">
                            <span class="slide-num">Slide #@slide.Order</span>
                            <div class="slide-mock-text">
                                <div class="mock-line" style="width:70%"></div>
                                <div class="mock-line" style="width:50%"></div>
                            </div>
                            @if (!string.IsNullOrEmpty(slide.ImageUrl))
                            {
                                <div class="image-hover-popover">
                                    <img src="@slide.ImageUrl" alt="@slide.Name">
                                </div>
                            }
                        </div>
                        <div class="slide-card-body">
                            <form method="post" action="/Admin/UpdateCarousel" enctype="multipart/form-data">
                                <input type="hidden" name="Id" value="@slide.Id">
                                <div class="form-group">
                                    <label>Title</label>
                                    <input type="text" name="Name" class="form-input" value="@slide.Name">
                                </div>
                                <div class="form-group">
                                    <label>Subtitle</label>
                                    <input type="text" name="Decription" class="form-input" value="@slide.Decription">
                                </div>
                                <div class="form-group">
                                    <label>Button Link</label>
                                    <input type="text" name="ButtonLink" class="form-input" value="@slide.ButtonLink">
                                </div>
                                <div class="form-group">
                                    <label>Background Image</label>
                                    <div class="file-upload-area">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                                        <span>Upload Image</span>
                                        <input type="file" name="imageFile" accept="image/*">
                                    </div>
                                </div>
                                <div class="slide-actions">
                                    <button type="submit" class="btn-primary btn-sm">Save</button>
                                    <button type="button" class="btn-danger btn-sm btn-slide-del" data-id="@slide.Id">Delete Slide</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<div class="modal-overlay" id="bookModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add Book</h3>
            <button class="modal-close" onclick="closeModal('bookModal')">&#10005;</button>
        </div>
        <form method="post" action="/Admin/CreateProduct" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Title *</label>
                        <input type="text" name="Name" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Price (&#8380;) *</label>
                        <input type="number" name="Price" step="0.01" class="form-input" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Cost Price (&#8380;)</label>
                        <input type="number" name="CostPrice" step="0.01" class="form-input" value="0">
                    </div>
                    <div class="form-group">
                        <label>Discount %</label>
                        <input type="number" name="DiscountPercent" step="0.01" class="form-input" value="0">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Author *</label>
                        <select name="AuthorId" class="form-input">
                            @foreach (var a in Model.Authors)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Genre *</label>
                        <select name="GenreId" class="form-input">
                            @foreach (var g in Model.Genres)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description" class="form-input form-textarea"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Cover Image</label>
                        <div class="file-upload-area">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                            <span>Upload cover image</span>
                            <input type="file" name="imageFile" accept="image/*">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Hover Image</label>
                        <div class="file-upload-area">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                            <span>Upload hover image</span>
                            <input type="file" name="hoverImageFile" accept="image/*">
                        </div>
                    </div>
                </div>
                <div class="form-row" style="align-items:center;padding-top:6px">
                    <div class="form-group" style="display:flex;gap:10px;align-items:center">
                        <input type="checkbox" name="IsFeatured" value="true" id="isFeatured">
                        <label for="isFeatured" style="margin:0">Featured</label>
                    </div>
                    <div class="form-group" style="display:flex;gap:10px;align-items:center">
                        <input type="checkbox" name="IsNew" value="true" id="isNew">
                        <label for="isNew" style="margin:0">New Arrival</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="closeModal('bookModal')">Cancel</button>
                <button type="submit" class="btn-primary">Add Book</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="confirmModal">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Confirm Deletion</h3>
            <button class="modal-close" onclick="closeModal('confirmModal')">&#10005;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px; color:#555; line-height:1.6;">
                Are you sure you want to delete this item? This action cannot be undone.
            </p>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('confirmModal')">Cancel</button>
            <button class="btn-danger" id="confirmDeleteBtn">Delete</button>
        </div>
    </div>
</div>

<!-- Add Slide Modal -->
<div class="modal-overlay" id="addSlideModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add Slide</h3>
            <button class="modal-close" onclick="closeModal('addSlideModal')">&#10005;</button>
        </div>
        <form method="post" action="/Admin/CreateCarousel" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="form-group">
                    <label>Title *</label>
                    <input type="text" name="Name" class="form-input" required>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" name="Decription" class="form-input" value="">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Button Text</label>
                        <input type="text" name="ButtonText" class="form-input">
                    </div>
                    <div class="form-group">
                        <label>Button Link</label>
                        <input type="text" name="ButtonLink" class="form-input" placeholder="/catalog">
                    </div>
                </div>
                <div class="form-group">
                    <label>Order</label>
                    <input type="number" name="Order" class="form-input" value="1">
                </div>
                <div class="form-group">
                    <label>Background Image</label>
                    <div class="file-upload-area">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                        <span>Upload Image</span>
                        <input type="file" name="imageFile" accept="image/*">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="closeModal('addSlideModal')">Cancel</button>
                <button type="submit" class="btn-primary">Add Slide</button>
            </div>
        </form>
    </div>
</div>

<form id="deleteProductForm" method="post" action="/Admin/DeleteProduct" style="display:none">
    <input type="hidden" name="id" id="deleteProductId">
</form>
<form id="deleteSlideForm" method="post" action="/Admin/DeleteCarousel" style="display:none">
    <input type="hidden" name="id" id="deleteSlideId">
</form>
<script defer src="~/admin/Script/admin_panel.js"></script>
</body>
</html>

