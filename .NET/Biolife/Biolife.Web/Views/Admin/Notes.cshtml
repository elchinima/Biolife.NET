@model Biolife.Application.ViewModels.AdminVm
@{
    Layout = null;
    var role = Model.CurrentUserRole;
    var canCreateNotes = role?.CreateNotes == true;
}
@functions {
    private static string GetNoteTypeLabel(NoteType type)
    {
        return type switch
        {
            NoteType.High => "High",
            NoteType.Immediate => "Immediate",
            _ => "Normal"
        };
    }

    private static string GetNoteTypeClass(NoteType type)
    {
        return type switch
        {
            NoteType.High => "note-high",
            NoteType.Immediate => "note-immediate",
            _ => "note-normal"
        };
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel.css">
    <link rel="stylesheet" href="~/admin/CSS/admin_panel_responsive.css">
    <style>
        .notes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .note-card {
            background: #fff;
            border: 1px solid #ececec;
            border-left-width: 5px;
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
            padding: 18px;
            height: 230px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .note-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
        }

        .note-card:focus-visible {
            outline: 2px solid var(--green);
            outline-offset: 3px;
        }

        .note-normal {
            border-left-color: #8a8f98;
        }

        .note-high {
            border-left-color: #f59e0b;
        }

        .note-immediate {
            border-left-color: #dc2626;
        }

        .note-head {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-start;
        }

        .note-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--gray);
            line-height: 1.35;
            word-break: break-word;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .note-text {
            color: #555;
            font-size: 13px;
            line-height: 1.6;
            white-space: pre-wrap;
            word-break: break-word;
            flex: 1;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
        }

        .note-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            color: #999;
            font-size: 11px;
            border-top: 1px solid #f1f1f1;
            padding-top: 12px;
        }

        .note-more {
            display: none;
            align-self: flex-start;
            color: var(--green-dark);
            font-size: 12px;
            font-weight: 700;
            margin-top: -4px;
        }

        .note-card.has-overflow .note-more {
            display: inline-flex;
        }

        .note-card-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .note-delete-form {
            margin: 0;
        }

        .note-delete-btn {
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #c0392b;
        }

        .note-delete-btn:hover {
            background: #fff2f2;
        }

        .note-detail-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            color: #777;
            font-size: 12px;
            margin-bottom: 14px;
        }

        .note-detail-text {
            color: #444;
            font-size: 14px;
            line-height: 1.7;
            white-space: pre-wrap;
            overflow-wrap: anywhere;
        }

        .note-empty {
            padding: 28px;
            text-align: center;
            color: #888;
            font-size: 14px;
        }

        .note-create-locked {
            font-size: 12px;
            color: #8a8a8a;
            background: #fff;
            border: 1px solid #e7e7e7;
            border-radius: 4px;
            padding: 10px 14px;
        }

        .badge-note-normal {
            background: #f1f2f4;
            color: #5f6670;
        }

        .badge-note-high {
            background: #fff3cd;
            color: #9a5b00;
        }

        .badge-note-immediate {
            background: #fde2e2;
            color: #a61b1b;
        }
    </style>
</head>
<body data-can-products="@(role?.Products == true ? "true" : "false")"
      data-can-slider="@(role?.Slider == true ? "true" : "false")"
      data-can-tags="@(role?.Tag == true ? "true" : "false")"
      data-can-genres="@(role?.Genres == true ? "true" : "false")"
      data-can-users="@(role?.Users == true ? "true" : "false")"
      data-can-roles="@(role?.Roles == true ? "true" : "false")"
      data-can-create-notes="@(role?.CreateNotes == true ? "true" : "false")"
      data-can-orders="@(role?.Orders == true ? "true" : "false")">

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo"><span class="logo-text">Admin<span>Panel</span></span></div>
        <nav class="sidebar-nav">
            <a href="/Admin/Index" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span>Dashboard</span>
            </a>
            <a href="/Admin/Products" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <span>Products</span>
            </a>
            <a href="/Admin/Carousel" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><polyline points="16 2 12 7 8 2" /></svg>
                <span>Slider</span>
            </a>
            <a href="/Admin/Tags" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="16" y1="11" x2="22" y2="11" /></svg>
                <span>Tags</span>
            </a>
            <a href="/Admin/Genres" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M3 12h18" /><path d="M3 18h18" /></svg>
                <span>Genres</span>
            </a>
            <a href="/Admin/Users" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                <span>Users</span>
            </a>
            <a href="/Admin/Roles" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-4z" /></svg>
                <span>Roles</span>
            </a>
            <a href="/Admin/Notes" class="nav-item active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16v16H4z" />
                    <path d="M8 8h8" />
                    <path d="M8 12h8" />
                    <path d="M8 16h5" />
                </svg>
                <span>Notes</span>
            </a>
            <a href="/Admin/Orders" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><path d="M3 6h18" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                <span>Orders</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/" class="nav-item nav-logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                <span>Exit to site</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
            </button>
            <h1 class="page-title">Notes</h1>
            <div class="topbar-right">
                <span class="topbar-date" id="topbarDate"></span>
                <div class="topbar-user">
                    <div class="user-avatar">@((!string.IsNullOrWhiteSpace(User.Identity?.Name) ? User.Identity.Name!.Substring(0, 1).ToUpperInvariant() : "A"))</div>
                    <span>@(string.IsNullOrWhiteSpace(User.Identity?.Name) ? "Admin" : User.Identity!.Name)</span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="page-actions">
                <div class="search-bar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" id="noteSearch" placeholder="Search note...">
                </div>
                @if (canCreateNotes)
                {
                    <button class="btn-primary" onclick="document.getElementById('addNoteModal').classList.add('open')">+ Add Note</button>
                }
                else
                {
                    <div class="note-create-locked">Create Notes permission is required to add notes.</div>
                }
            </div>

            @if (Model.Notes.Count == 0)
            {
                <div class="card note-empty">No notes yet.</div>
            }
            else
            {
                <div class="notes-grid" id="notesGrid">
                    @foreach (var note in Model.Notes)
                    {
                        var typeClass = GetNoteTypeClass(note.Type);
                        var badgeClass = $"badge-note-{typeClass.Replace("note-", string.Empty)}";
                        <article class="note-card @typeClass" role="button" tabindex="0" aria-label="Open note details" data-note-search="@($"{note.Title} {note.Text} {note.CreatedByUser?.Name} {GetNoteTypeLabel(note.Type)}".ToLowerInvariant())">
                            <div class="note-head">
                                <h2 class="note-title">@note.Title</h2>
                                <div class="note-card-actions">
                                    <span class="badge @badgeClass">@GetNoteTypeLabel(note.Type)</span>
                                    <form method="post" action="/Admin/DeleteNote" class="note-delete-form">
                                        <input type="hidden" name="id" value="@note.Id">
                                        <button type="submit" class="btn-icon note-delete-btn" title="Delete note" aria-label="Delete note" onclick="event.stopPropagation(); return confirm('Delete this note?');">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M3 6h18" />
                                                <path d="M8 6V4h8v2" />
                                                <path d="M19 6l-1 14H6L5 6" />
                                                <path d="M10 11v6" />
                                                <path d="M14 11v6" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="note-text">@note.Text</div>
                            <span class="note-more">Continue</span>
                            <div class="note-meta">
                                <span>@(note.CreatedByUser?.Name ?? "Unknown")</span>
                                <span>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                            </div>
                        </article>
                    }
                </div>
            }
        </main>
    </div>

    @if (canCreateNotes)
    {
        <div class="modal-overlay" id="addNoteModal">
            <div class="modal">
                <div class="modal-header">
                    <h3>Add Note</h3>
                    <button class="modal-close" onclick="document.getElementById('addNoteModal').classList.remove('open')">&#10005;</button>
                </div>
                <form method="post" action="/Admin/CreateNote">
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Title *</label>
                            <input type="text" name="title" class="form-input" maxlength="120" required>
                        </div>
                        <div class="form-group">
                            <label>Type *</label>
                            <select name="type" class="form-input" required>
                                <option value="@((int)NoteType.Normal)">Normal</option>
                                <option value="@((int)NoteType.High)">High</option>
                                <option value="@((int)NoteType.Immediate)">Immediate</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Text *</label>
                            <textarea name="text" class="form-input form-textarea" maxlength="1000" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" onclick="document.getElementById('addNoteModal').classList.remove('open')">Cancel</button>
                        <button type="submit" class="btn-primary">Create Note</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="modal-overlay" id="noteDetailsModal">
        <div class="modal">
            <div class="modal-header">
                <h3 id="noteDetailsTitle">Note</h3>
                <button type="button" class="modal-close" id="noteDetailsCloseBtn">&#10005;</button>
            </div>
            <div class="modal-body">
                <div class="note-detail-meta">
                    <span id="noteDetailsType"></span>
                    <span id="noteDetailsTag"></span>
                    <span id="noteDetailsDate"></span>
                </div>
                <div class="note-detail-text" id="noteDetailsText"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" id="noteDetailsFooterCloseBtn">Close</button>
            </div>
        </div>
    </div>

    <script defer src="~/admin/Script/admin_panel.js"></script>
    <script>
        const noteDetailsModal = document.getElementById('noteDetailsModal');
        const closeNoteDetails = () => noteDetailsModal?.classList.remove('open');

        document.getElementById('noteDetailsCloseBtn')?.addEventListener('click', closeNoteDetails);
        document.getElementById('noteDetailsFooterCloseBtn')?.addEventListener('click', closeNoteDetails);
        noteDetailsModal?.addEventListener('click', event => {
            if (event.target === noteDetailsModal) closeNoteDetails();
        });

        document.querySelectorAll('#notesGrid .note-card').forEach(card => {
            const markOverflow = () => {
                const title = card.querySelector('.note-title');
                const text = card.querySelector('.note-text');
                const hasOverflow = (title && title.scrollHeight > title.clientHeight + 1)
                    || (text && text.scrollHeight > text.clientHeight + 1);
                card.classList.toggle('has-overflow', Boolean(hasOverflow));
            };

            requestAnimationFrame(markOverflow);
            window.addEventListener('resize', markOverflow);

            const openDetails = () => {
                document.getElementById('noteDetailsTitle').textContent = card.querySelector('.note-title')?.textContent?.trim() || 'Note';
                document.getElementById('noteDetailsType').textContent = card.querySelector('.badge')?.textContent?.trim() || '';
                document.getElementById('noteDetailsText').textContent = card.querySelector('.note-text')?.textContent || '';

                const metaItems = card.querySelectorAll('.note-meta span');
                document.getElementById('noteDetailsTag').textContent = metaItems[0]?.textContent?.trim() || '';
                document.getElementById('noteDetailsDate').textContent = metaItems[1]?.textContent?.trim() || '';
                noteDetailsModal?.classList.add('open');
            };

            card.addEventListener('click', event => {
                if (event.target.closest('button, form, a')) return;
                openDetails();
            });

            card.addEventListener('keydown', event => {
                if (event.key !== 'Enter' && event.key !== ' ') return;
                if (event.target.closest('button, form, a')) return;
                event.preventDefault();
                openDetails();
            });
        });

        document.getElementById('noteSearch')?.addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            document.querySelectorAll('#notesGrid .note-card').forEach(card => {
                const haystack = (card.getAttribute('data-note-search') || '').toLowerCase();
                card.style.display = haystack.includes(q) ? '' : 'none';
            });
        });
    </script>
</body>
</html>

